{
    "name":  "@clawshield/agent",
    "version":  "1.0.0",
    "private":  true,
    "type":  "module",
    "bin":  {
                "clawshield-agent":  "./dist/index.js"
            },
    "scripts":  {
                    "build":  "tsc",
                    "dev":  "tsx src/index.ts",
                    "start":  "node dist/index.js",
                    "demo":  "tsx src/index.ts --demo risky",
                    "seed:mantle": "node scripts/seed-mantle-decisions.mjs",
                    "showcase":  "tsx src/index.ts --demo --showcase risky",
                    "arena":  "tsx src/arena.ts --demo"
                },
    "dependencies":  {
                         "@clawshield/adapters":  "workspace:*",
                         "@clawshield/core":  "workspace:*",
                         "@clawshield/sdk":  "workspace:*",
                         "dotenv":  "^16.4.7",
                         "viem":  "^2.21.0"
                     },
    "devDependencies":  {
                            "@types/node":  "^22.10.0",
                            "tsx":  "^4.19.2",
                            "typescript":  "^5.7.2"
                        }
}
