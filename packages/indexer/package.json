{
  "name": "@clawshield/indexer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const p=require('path');const s=p.join('src','migrations');const d=p.join('dist','migrations');fs.cpSync(s,d,{recursive:true});\"",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "index": "tsx src/cli.ts",
    "test": "node --experimental-sqlite --import tsx --test src/query.test.ts"
  },
  "dependencies": {
    "viem": "^2.21.54"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
